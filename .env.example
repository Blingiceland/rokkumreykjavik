# Optional: forward newsletter signups. Default setup is a Google Apps Script
# web-app URL that appends each signup to a Sheet — see
# docs/newsletter-google-sheet.md. Works for Buttondown/Zapier hooks too.
NEWSLETTER_WEBHOOK=

# Poster hub (/artist) — set these in production (e.g. Vercel env vars).
# Without them, dev falls back to the password "rokk2026".
ADMIN_PASSWORD=skiptu-mer-ut
# Optional salt for the auth cookie token. Change it to invalidate old sessions.
ADMIN_SECRET=rokk-poster-salt-2026
